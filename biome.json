{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noExcessiveCognitiveComplexity": {
					"level": "warn",
					"options": { "maxAllowedComplexity": 25 }
				}
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"overrides": [
		{
			"include": ["tests/**"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off",
						"noUnusedTemplateLiteral": "off"
					}
				}
			}
		},
		{
			"include": ["src/plugins/**", "src/source/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	],
	"files": {
		"ignore": [
			"dist",
			"node_modules",
			"test-results",
			"playwright-report",
			"tests/unit/source/fixtures",
			"src/recorder/generated",
			"src/recorder/browser/*.entry.ts"
		]
	}
}
